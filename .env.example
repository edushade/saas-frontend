# Mailtrap / SMTP (for contact form or email sending)
# Get credentials from https://mailtrap.io → Inboxes → SMTP Settings
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=sandbox.smtp.mailtrap.io
EMAIL_SMTP_PORT=2525
EMAIL_SMTP_USERNAME=8e02fed3cd5e48
EMAIL_SMTP_PASSWORD=81bcaef900d225

# Sender (From) and recipient (To). Required to avoid "Sending from domain mailtrap.io is not allowed".
# Use your own domain or a sender your SMTP allows — never use the provider's domain (e.g. @mailtrap.io) as From.
EMAIL_FROM=Edushade Contact <noreply@edushade.com>
EMAIL_TO=sales@edushade.com

# Site origin for canonical URLs, OG tags, and prerender base.
# Production: set to https://edushade.com (or your domain).
# Development: leave unset to use http://localhost:3000, or set to override (e.g. http://localhost:5173).
VITE_SITE_ORIGIN=https://edushade.com
SITE_ORIGIN=https://edushade.com
